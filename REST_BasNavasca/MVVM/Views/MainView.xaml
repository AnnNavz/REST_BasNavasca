<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="REST_BasNavasca.MVVM.Views.MainView"
             Title="MainView"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <Grid>
        <VerticalStackLayout HorizontalOptions="Center">
            <Border WidthRequest="403" HeightRequest="100" BackgroundColor="#1fa0ff" Stroke="Transparent">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0,0,15,15"/>
                </Border.StrokeShape>
                
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="3" Opacity="0.2"/>
                </Border.Shadow>

                <HorizontalStackLayout>

                    <Image Source="option.png"
                           WidthRequest="35"
                           Margin="30,10,0,0"
                           HorizontalOptions="Start"/>

                    <Label Text="Vehicle Renters"
                       FontFamily="Outfit-ExtraBold"
                       FontSize="24"
                       VerticalTextAlignment="Center"
                       Margin="50,0,0,0"
                       TextColor="White"/>

                </HorizontalStackLayout>
            </Border>

            <Border WidthRequest="390" HeightRequest="130" Stroke="#c0c0c0" StrokeThickness="1" BackgroundColor="White" Margin="0,30,0,0">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#5d7689" Offset="0,0" Radius="4" Opacity="0.3"/>
                </Border.Shadow>

                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,Auto,Auto">

                    <Image Source="user.png"
                           WidthRequest="80"
                           Grid.RowSpan="3"
                           Margin="20"/>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="0,15,0,0">
                        <Label Text="Marven James Bas"
                               FontFamily="Outfit-Regular"
                               FontSize="18"
                               TextColor="Black"
                            />
                        <Label Text="Date: December 20, 2026"
                               FontFamily="Outfit-Regular"
                               FontSize="12"
                               TextColor="#696969"
                               Margin="0,10,0,0"
                           />
                        <Label Text="Time: 8 AM - 12 AM"
                               FontFamily="Outfit-Regular"
                               FontSize="12"
                               TextColor="#696969"
                               Margin="0,2,0,0"
                           />
                        <Label Text="Vehicle Type: SUV Hatdog"
                               FontFamily="Outfit-Regular"
                               FontSize="12"
                               TextColor="#696969"
                               Margin="0,2,0,0"
                           />

                    </VerticalStackLayout>



                    <Image Source="edit.png"
                           WidthRequest="30"
                           Grid.Column="2"
                           VerticalOptions="Start"
                           Margin="50,20,0,0"/>



                </Grid>
            </Border>

            <Border WidthRequest="390" HeightRequest="130" StrokeThickness="1"  Stroke="#c0c0c0" BackgroundColor="White" Margin="0,10,0,0">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#5d7689" Offset="0,0" Radius="4" Opacity="0.3"/>
                </Border.Shadow>

                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,Auto,Auto">

                    <Image Source="user.png"
                           WidthRequest="80"
                           Grid.RowSpan="3"
                           Margin="20"/>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="0,15,0,0">
                        <Label Text="Ann Shirley Navasca"
                               FontFamily="Outfit-Regular"
                               FontSize="18"
                               TextColor="Black"
                            />
                        <Label Text="Date: October 14, 2026"
                               FontFamily="Outfit-Regular"
                               FontSize="12"
                               TextColor="#696969"
                               Margin="0,10,0,0"
                           />
                        <Label Text="Time: 1 PM - 6 PM"
                               FontFamily="Outfit-Regular"
                               FontSize="12"
                               TextColor="#696969"
                               Margin="0,2,0,0"
                           />
                        <Label Text="Vehicle Type: SUV Hatdog"
                               FontFamily="Outfit-Regular"
                               FontSize="12"
                               TextColor="#696969"
                               Margin="0,2,0,0"
                           />

                    </VerticalStackLayout>



                    <Image Source="edit.png"
                           WidthRequest="30"
                           Grid.Column="2"
                           VerticalOptions="Start"
                           Margin="50,20,0,0"/>

                    



                </Grid>
            </Border>

            <Border WidthRequest="390" HeightRequest="130" Stroke="#c0c0c0" StrokeThickness="1" BackgroundColor="White" Margin="0,10,0,0">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#5d7689" Offset="0,0" Radius="4" Opacity="0.3"/>
                </Border.Shadow>

                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,Auto,Auto">

                    <Image Source="user.png"
                           WidthRequest="80"
                           Grid.RowSpan="3"
                           Margin="20"/>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="0,15,0,0">
                        <Label Text="Marley Bas"
                               FontFamily="Outfit-Regular"
                               FontSize="18"
                               TextColor="Black"
                            />
                        <Label Text="Date: May 20, 2026"
                               FontFamily="Outfit-Regular"
                               FontSize="12"
                               TextColor="#696969"
                               Margin="0,10,0,0"
                           />
                        <Label Text="Time: Overnight"
                               FontFamily="Outfit-Regular"
                               FontSize="12"
                               TextColor="#696969"
                               Margin="0,2,0,0"
                           />
                        <Label Text="Vehicle Type: SUV Hatdog"
                               FontFamily="Outfit-Regular"
                               FontSize="12"
                               TextColor="#696969"
                               Margin="0,2,0,0"
                           />

                    </VerticalStackLayout>



                    <Image Source="edit.png"
                           WidthRequest="30"
                           Grid.Column="2"
                           VerticalOptions="Start"
                           Margin="50,20,0,0"/>

                    


                </Grid>
            </Border>


        </VerticalStackLayout>

        <ImageButton Source="plus.png"
                     WidthRequest="80"
                     VerticalOptions="End"
                     HorizontalOptions="End"
                     Margin="30"
                     Clicked="ImageButton_Clicked"
               />
    </Grid>
</ContentPage>
