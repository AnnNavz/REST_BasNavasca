<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="REST_BasNavasca.MVVM.Views.User"
             Title="User"
             NavigationPage.HasNavigationBar="False"
             BackgroundImageSource="imagebg.png">

    <VerticalStackLayout>
        <Label Text="Details"
               FontSize="24"
               FontFamily="OutfitBold"
               Margin="0,15,0,0"
               TextColor="White"
               HorizontalOptions="Center"/>
        <Label Text="Renters information and its reservation details."
               FontSize="14"
               FontFamily="OutfitRegular"
               Margin="0,5,0,20"
               TextColor="White"
               HorizontalOptions="Center"/>

        <Border BackgroundColor="White" WidthRequest="360" HeightRequest="210" Stroke="Transparent" Padding="20,25,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="0,3"
                        Radius="6"
                        Opacity="0.4"/>
            </Border.Shadow>
            
            <VerticalStackLayout>
                

                <Grid RowDefinitions="auto,auto"
              ColumnDefinitions="auto,auto">


                    <Image Source="marvenuser.png"
                       WidthRequest="80"
                       Grid.RowSpan="2"
                       Margin="10,0,15,0"
                       HorizontalOptions="Center"/>

                    <VerticalStackLayout Grid.Column="1">

                        <Label Text="Name"
                       FontSize="15"
                       FontFamily="OutfitSemibold"
                       TextColor="Black"
                           Margin="0,0,0,5"/>

                        <Entry Text="Marven James Bas"
                           x:Name="NameEntry"
                           IsEnabled="False"
                           TextColor="Black"
                           WidthRequest="200"
                           BackgroundColor="#dfe8f5"
                           FontSize="12"
                           FontFamily="OutfitRegular"/>


                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Grid.Row="1" Margin="0,15,0,0">

                        <Label Text="Contact Number"
                       FontSize="15"
                       FontFamily="OutfitSemibold"
                       TextColor="Black"
                           Margin="0,0,0,5"/>

                        <Entry Text="0920 215 6578" 
                           x:Name="ContactEntry"
                           IsEnabled="False"
                           TextColor="Black"
                           WidthRequest="200"
                           BackgroundColor="#dfe8f5"
                           FontSize="12"
                           FontFamily="OutfitRegular"/>


                    </VerticalStackLayout>

                </Grid>

            </VerticalStackLayout>


        </Border>

        <Border WidthRequest="360" HeightRequest="400" BackgroundColor="White" Stroke="Transparent" Padding="20" Margin="0,10,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="0,3"
                        Radius="6"
                        Opacity="0.4"/>
            </Border.Shadow>

            <Grid RowDefinitions="0.1*, 0.7*">


                <HorizontalStackLayout>
                    <Label Text="Reservation"
                           FontSize="20"
                           FontFamily="OutfitSemibold"
                           Margin="10,5,0,0"
                           TextColor="Black"/>

                    <Button Text="Edit"
                            IsVisible="True"
                            WidthRequest="80"
                            HeightRequest="20"
                            TextColor="White"
                            FontFamily="OutfitSemibold"
                            BackgroundColor="#FFA826"
                            Margin="110,0,0,0"
                            x:Name="Update"
                            Clicked="Update_Clicked"/>
                </HorizontalStackLayout>
                
                <VerticalStackLayout Grid.Row="1">

                    <Label Text="Date"
                        FontSize="14"
                        FontFamily="OutfitRegular"
                        Margin="10,10,0,10"
                        TextColor="Black"/>

                    <DatePicker Date="05/20/2024"
                            x:Name="DatePicker" 
                            IsEnabled="False" 
                            TextColor="Black" 
                            Background="#dfe8f5"
                            WidthRequest="300"
                            FontFamily="OutfitRegular"/>

                    <Label Text="Destination Address"
                    FontSize="14"
                    FontFamily="OutfitRegular"
                    Margin="10,10,0,10"
                    TextColor="Black"/>

                    <Entry Text="Basdiot, Moalboal"
                           x:Name="AddressEntry" 
                           IsEnabled="False"
                           TextColor="Black"
                           WidthRequest="300"
                           BackgroundColor="#dfe8f5"
                           FontSize="14"
                           FontFamily="OutfitRegular"/>

                    <Label Text="Vehicle Type"
                    FontSize="14"
                    FontFamily="OutfitRegular"
                    Margin="10,10,0,10"
                    TextColor="Black"/>

                    <Grid>

                        <Entry Text="SUV Hatdog"
                           IsVisible="True" 
                           IsEnabled="False"
                           x:Name="VehicleEntryData"
                           TextColor="Black"
                           WidthRequest="300"
                           BackgroundColor="#dfe8f5"
                           FontSize="14"
                           FontFamily="OutfitRegular"/>

                        <Picker x:Name="VehiclePicker" 
                            WidthRequest="300"
                            IsVisible="False"
                            BackgroundColor="#dfe8f5">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>SUV Hatdog</x:String>
                                    <x:String>Sedan</x:String>
                                    <x:String>Nissan Van</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>

                    </Grid>


                    <Button Text="Update"
                            x:Name="SubmitUpdate"
                            IsVisible="False"
                            WidthRequest="80"
                            HeightRequest="20"
                            FontFamily="OutfitSemibold"
                            BackgroundColor="#FFA826"
                            HorizontalOptions="Center"
                            TextColor="White"
                            Margin="0,20,0,0"/>




                </VerticalStackLayout>

            </Grid>



        </Border>
    </VerticalStackLayout>
</ContentPage>