<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="REST_BasNavasca.MVVM.Views.User"
             Title="User"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <VerticalStackLayout>

        <Border BackgroundColor="Transparent" WidthRequest="400" HeightRequest="190" Stroke="Transparent">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,16,16"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="0,3"
                        Radius="6"
                        Opacity="0.4"/>
            </Border.Shadow>

            <Grid>

                <Image Source="imagebg.png"
                       Aspect="AspectFill"/>

                <Grid RowDefinitions="auto">


                    <Button Text="Edit"
                            IsVisible="True"
                            WidthRequest="80"
                            HeightRequest="20"
                            TextColor="White"
                            FontFamily="OutfitSemibold"
                            BackgroundColor="#60FFFFFF"
                            Margin="0,10,20,0"
                            x:Name="Update"
                            Clicked="Update_Clicked"
                            HorizontalOptions="End"/>


                    <Button Text="Cancel"
                            IsVisible="False"
                            WidthRequest="80"
                            HeightRequest="20"
                            TextColor="White"
                            FontFamily="OutfitSemibold"
                            BackgroundColor="#60FFFFFF"
                            Margin="0,10,20,0"
                            x:Name="CancelUpdate"
                            Clicked="CancelUpdate_Clicked"
                            HorizontalOptions="End"/>
                </Grid>

                <Frame WidthRequest="400" HeightRequest="150" BackgroundColor="Transparent" BorderColor="Transparent" VerticalOptions="End">

                    <VerticalStackLayout>


                        <Grid RowDefinitions="auto,auto"
                          ColumnDefinitions="1*,0.5*">

                            <Border Grid.RowSpan="2"
                                Grid.Column="1"
                                WidthRequest="80"
                                HeightRequest="80"
                                StrokeThickness="0"
                                HorizontalOptions="Center"
                                Margin="25,0,15,0">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="40,40,40,40" />
                                </Border.StrokeShape>

                                <Image Source="user.png"
                                   x:Name="UserProfileImage"
                                   Aspect="AspectFill"
                                   WidthRequest="80"
                                   HeightRequest="80"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="0">

                                <Label Text="Renter"
                                       FontSize="12"
                                       FontFamily="OutfitRegular"
                                       TextColor="White"
                                       Margin="10,0,0,0"/>

                                <Entry Text="Marven James Bas"
                           x:Name="NameEntry"
                           IsEnabled="False"
                           TextColor="White"
                           WidthRequest="240"
                           BackgroundColor="Transparent"
                           FontSize="20"
                           FontFamily="OutfitBold"/>


                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="0" Grid.Row="1" Margin="0,0,0,0">

                                <Entry Text="0920 215 6578" 
                           x:Name="ContactEntry"
                           IsEnabled="False"
                           TextColor="White"
                           WidthRequest="240"
                           BackgroundColor="Transparent"
                           FontSize="12"
                           FontFamily="OutfitRegular"/>


                            </VerticalStackLayout>

                        </Grid>

                    </VerticalStackLayout>


                </Frame>

            </Grid>

        </Border>

        <Border WidthRequest="380" HeightRequest="360" BackgroundColor="White" Stroke="Transparent" Padding="20" Margin="0,20,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="0,3"
                        Radius="6"
                        Opacity="0.4"/>
            </Border.Shadow>

            <Grid RowDefinitions="0.1*, 0.7*">


                <HorizontalStackLayout>
                    <Label Text="Reservation Details"
                           FontSize="20"
                           FontFamily="OutfitSemibold"
                           Margin="10,5,0,0"
                           TextColor="Black"/>
                </HorizontalStackLayout>
                
                <VerticalStackLayout Grid.Row="1">

                    <Label Text="Date"
                        FontSize="14"
                        FontFamily="OutfitRegular"
                        Margin="10,10,0,10"
                        TextColor="Black"/>

                    <DatePicker Date="05/20/2024"
                            x:Name="DatePicker" 
                            IsEnabled="False" 
                            TextColor="Black" 
                            Background="#dfe8f5"
                            WidthRequest="320"
                            FontFamily="OutfitRegular"/>

                    <Label Text="Destination Address"
                    FontSize="14"
                    FontFamily="OutfitRegular"
                    Margin="10,10,0,10"
                    TextColor="Black"/>

                    <Entry Text="Basdiot, Moalboal"
                           x:Name="AddressEntry" 
                           IsEnabled="False"
                           TextColor="Black"
                           WidthRequest="320"
                           BackgroundColor="#dfe8f5"
                           FontSize="14"
                           FontFamily="OutfitRegular"/>

                    <Label Text="Vehicle Type"
                    FontSize="14"
                    FontFamily="OutfitRegular"
                    Margin="10,10,0,10"
                    TextColor="Black"/>

                    <Grid>

                        <Entry Text="SUV Hatdog"
                           IsVisible="True" 
                           IsEnabled="False"
                           x:Name="VehicleEntryData"
                           TextColor="Black"
                           WidthRequest="320"
                           BackgroundColor="#dfe8f5"
                           FontSize="14"
                           FontFamily="OutfitRegular"/>

                        <Picker x:Name="VehiclePicker" 
                            WidthRequest="320"
                            IsVisible="False"
                            BackgroundColor="#dfe8f5"
                                TextColor="Black"
                                FontFamily="OutfitRegular">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>SUV Hatdog</x:String>
                                    <x:String>Sedan</x:String>
                                    <x:String>Nissan Van</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>

                    </Grid>

                </VerticalStackLayout>

            </Grid>



        </Border>




        <Button Text="Update Renter"
                x:Name="SubmitUpdate"
                IsVisible="False"
                WidthRequest="150"
                HeightRequest="50"
                FontFamily="OutfitSemibold"
                BackgroundColor="#FFA826"
                HorizontalOptions="Center"
                TextColor="White"
                Margin="0,30,0,0"/>
    </VerticalStackLayout>
</ContentPage>