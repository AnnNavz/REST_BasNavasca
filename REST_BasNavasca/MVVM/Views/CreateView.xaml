<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="REST_BasNavasca.MVVM.Views.CreateView"
             Title="CreateView"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#1fa0ff">

    <ScrollView>

        <VerticalStackLayout VerticalOptions="Center">

            <Label Text="Register a Renter"
               FontSize="24"
               FontFamily="OutfitBold"
               TextColor="White"
               HorizontalOptions="Center"
               Margin="0,20,0,0"/>

            <Label Text="Fill-up the informations below to rent a car."
               FontSize="14"
               FontFamily="OutfitRegular"
               TextColor="White"
               Margin="0,5,0,25"
               HorizontalOptions="Center"/>


            <Border BackgroundColor="White" WidthRequest="350" HeightRequest="330" Stroke="Transparent">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black"
                        Offset="0,3"
                        Radius="6"
                        Opacity="0.4"/>
                </Border.Shadow>


                <VerticalStackLayout>


                    <Image Source="addprofile.png"
                       WidthRequest="100"
                       Grid.RowSpan="2"
                       HorizontalOptions="Center"
                       Margin="0,25,0,0"/>

                    <Label Text="Your Name"
                       FontSize="16"
                       FontFamily="OutfitSemibold"
                       TextColor="Black"
                           Margin="25,20,0,5"/>

                    <Entry x:Name="NameEntry"
                           Text="{Binding NewRenterName}"
                           TextColor="Black"
                           WidthRequest="290"
                           BackgroundColor="#60FFFFFF"
                           FontSize="12"
                           FontFamily="OutfitRegular"
                       Margin="0,0,0,15"
                               />

                    <Label Text="Contact Info"
                       FontSize="16"
                       FontFamily="OutfitSemibold"
                       TextColor="black"
                           Margin="25,0,0,5"/>

                    <Entry x:Name="ContactEntry"
                           Text="{Binding NewContactInfo}"
                           TextColor="Black"
                           WidthRequest="290"
                           BackgroundColor="#60FFFFFF"
                           FontSize="12"
                           FontFamily="OutfitRegular"/>



                </VerticalStackLayout>
            </Border>

            <Label Text="Reservation Details"
                       FontSize="20"
                       FontFamily="OutfitSemibold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       Margin="0,20,0,10"/>


            <Border BackgroundColor="White" WidthRequest="350" HeightRequest="350" Stroke="Transparent" Margin="0,0,0,50">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black"
                Offset="0,3"
                Radius="6"
                Opacity="0.4"/>
                </Border.Shadow>

                <VerticalStackLayout>

                    <Label Text="Date"
                    FontSize="14"
                    FontFamily="OutfitSemibold"
                    Margin="25,25,0,10"
                    TextColor="Black"/>

                    <DatePicker x:Name="DatePicker" 
                                Date="{Binding NewDate}"
                            TextColor="Black" 
                            WidthRequest="290"
                            FontFamily="OutfitRegular"/>

                    <Label Text="Destination Address"
                    FontSize="14"
                    FontFamily="OutfitSemibold"
                    Margin="25,10,0,10"
                    TextColor="Black"/>

                    <Entry x:Name="AddressEntry" 
                           Text="{Binding NewAddress}"
                           TextColor="Black"
                           WidthRequest="290"
                           BackgroundColor="#60FFFFFF"
                           FontSize="14"
                           FontFamily="OutfitRegular"/>

                    <Label Text="Vehicle Type"
                    FontSize="14"
                    FontFamily="OutfitSemibold"
                    Margin="25,10,0,10"
                    TextColor="Black"/>

                    <Grid>

                        <Picker x:Name="VehiclePicker" 
                        WidthRequest="290"
                                SelectedItem="{Binding NewVehicleType}">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>SUV Hatdog</x:String>
                                    <x:String>Sedan</x:String>
                                    <x:String>Nissan Van</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>

                    </Grid>


                    <Button Text="Submit"
                        x:Name="SubmitUpdate"
                            Command="{Binding AddRenterCommand}"
                        WidthRequest="100"
                        HeightRequest="20"
                        FontFamily="OutfitSemibold"
                        BackgroundColor="#FFA826"
                        HorizontalOptions="Center"
                        Margin="0,20,0,0"/>

                </VerticalStackLayout>

            </Border>
        </VerticalStackLayout>


    </ScrollView>
    
    
</ContentPage>